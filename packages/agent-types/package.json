{
  "name": "@purityjs/agent-types",
  "version": "0.1.0",
  "description": "Shared TypeScript contracts for Purity's self-improving agent control plane",
  "keywords": [
    "agent",
    "evals",
    "memory",
    "skills",
    "types"
  ],
  "license": "MIT",
  "author": "KoalaFacts",
  "repository": {
    "type": "git",
    "url": "https://github.com/KoalaFacts/Purity",
    "directory": "packages/agent-types"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp build && vp exec tsc --emitDeclarationOnly"
  }
}
