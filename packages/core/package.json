{
  "name": "@purity/core",
  "version": "0.1.0",
  "description": "Minimal, lightweight, super performant web framework using native signals",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.ts"
    },
    "./compiler": {
      "types": "./src/compiler/index.d.ts",
      "import": "./src/compiler/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run"
  },
  "keywords": [
    "signals",
    "reactive",
    "framework",
    "web-components",
    "no-virtual-dom",
    "lightweight"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KoalaFacts/Purity",
    "directory": "packages/core"
  },
  "author": "KoalaFacts",
  "license": "MIT",
  "dependencies": {
    "signal-polyfill": "^0.2.2"
  }
}
