{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["benchmark/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          },
          "a11y": {
            "useValidAnchor": "off",
            "useAnchorContent": "off",
            "useButtonType": "off",
            "noLabelWithoutControl": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": ["**", "!!**/dist", "!!**/node_modules", "!!gh-pages"]
  }
}
