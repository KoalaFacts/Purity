{
  "name": "purity",
  "version": "0.1.0",
  "description": "A minimal, lightweight, super performant web framework using native signals",
  "type": "module",
  "main": "dist/purity.cjs",
  "module": "dist/purity.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/purity.js",
      "require": "./dist/purity.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite examples"
  },
  "keywords": [
    "signals",
    "reactive",
    "framework",
    "lightweight",
    "no-virtual-dom"
  ],
  "license": "MIT",
  "dependencies": {
    "signal-polyfill": "^0.2.2"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "jsdom": "^25.0.0",
    "rollup": "^4.28.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
