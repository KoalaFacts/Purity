{
  "name": "@purityjs/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for AOT template compilation in Purity",
  "keywords": [
    "aot",
    "compiler",
    "plugin",
    "purity",
    "vite"
  ],
  "license": "MIT",
  "author": "KoalaFacts",
  "repository": {
    "type": "git",
    "url": "https://github.com/KoalaFacts/Purity",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@purityjs/core": "^0.1.0",
    "vite": ">=6.0.0"
  }
}
