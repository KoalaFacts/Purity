{
  "name": "@purityjs/core",
  "version": "0.1.0",
  "description": "Minimal, lightweight, super performant web framework using native signals",
  "keywords": [
    "framework",
    "lightweight",
    "no-virtual-dom",
    "reactive",
    "signals",
    "web-components"
  ],
  "license": "MIT",
  "author": "KoalaFacts",
  "repository": {
    "type": "git",
    "url": "https://github.com/KoalaFacts/Purity",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./compiler": {
      "development": "./src/compiler/index.ts",
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "require": "./dist/compiler/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "bench": "vitest bench --run"
  }
}
