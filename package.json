{
  "name": "purity-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "benchmark"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write ."
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "25.5.2",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.2"
  }
}
